FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here
HOST=0.0.0.0
PORT=8080
DATABASE_URL=
REDIS_URL=
LOG_LEVEL=INFO
API_VERSION=v1
AGENT_HEARTBEAT_INTERVAL=30

# MongoDB
MONGO_URI=mongodb://localhost:27017/open-claw

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here

# Fortress v2
FORTRESS_ENABLED=true
FORTRESS_SANDBOX_TIMEOUT=30
FORTRESS_MAX_WORKERS=4
FORTRESS_DATA_DIR=/tmp/fortress
