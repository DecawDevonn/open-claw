# ══════════════════════════════════════════════════════════════════════════════
# Devonn.AI / OpenClaw — Environment Variables Template
# Copy to .env and fill in your values. NEVER commit your .env to source control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Flask core ────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=False
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-secret
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
API_VERSION=v1
AGENT_HEARTBEAT_INTERVAL=30

# ── JWT / Authentication ──────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-jwt
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# OAuth 2.0 (Google, GitHub, etc.)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# AES / KMS encryption key
ENCRYPTION_KEY=

# ── 🧠 AI Model & NLP APIs ────────────────────────────────────────────────────
# OpenAI — text generation, embeddings, DALL·E, Whisper
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# HuggingFace — custom NLP models & embeddings
# https://huggingface.co/settings/tokens
HF_API_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# StabilityAI — image generation (SDXL)
# https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# DeepL — translation
# https://www.deepl.com/account/summary
DEEPL_API_KEY=

# ── 🔁 Automation & Workflow Orchestration ────────────────────────────────────
# Pabbly Connect — task automation
PABBLY_API_KEY=

# ElectroNeek — RPA
ELECTRONEEK_API_KEY=

# n8n / Make.com — webhook triggers
WEBHOOK_SECRET_KEY=
INTEGRATION_KEY=

# WebSocket server auth token
WS_AUTH_TOKEN=

# ── 🗃️ Data Storage, DB & Search ─────────────────────────────────────────────
# MongoDB
MONGO_URL=mongodb://localhost:27017

# PostgreSQL (Cloud)
PG_USER=
PG_PASS=
PG_URL=

# Redis
REDIS_URL=

# Generic DATABASE_URL (used by some ORMs)
DATABASE_URL=

# Airtable
# https://airtable.com/account
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Google Sheets (API key auth)
# https://console.cloud.google.com/apis/credentials
GOOGLE_SHEETS_API_KEY=

# ── 🗣️ Voice, Video, Speech ───────────────────────────────────────────────────
# ElevenLabs — text-to-speech
# https://elevenlabs.io/app/speech-synthesis
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# AssemblyAI — speech-to-text / audio intelligence
# https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=

# YouTube Data API
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# ── 🌐 Web & Browser Integrations ────────────────────────────────────────────
# SerpAPI — Google / Bing search scraping
# https://serpapi.com/dashboard
SERPAPI_KEY=

# Apify — browser automation & scraping
# https://console.apify.com/account/integrations
APIFY_API_KEY=

# ── 🗂️ Search & Contextual Retrieval ─────────────────────────────────────────
# Pinecone — vector DB
# https://app.pinecone.io
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=openclaw

# Algolia — full-text search
# https://www.algolia.com/account/api-keys
ALGOLIA_API_KEY=
ALGOLIA_APP_ID=

# ── 📊 Dashboards & Monitoring ────────────────────────────────────────────────
# Sentry — error tracking
# https://sentry.io/settings/account/api/auth-tokens/
SENTRY_DSN=

# Boost.Space — dashboard integration
BOOSTSPACE_API_KEY=

# ── 📣 Communications — Twilio ────────────────────────────────────────────────
# https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# WhatsApp sender (defaults to whatsapp:<TWILIO_FROM_NUMBER> when omitted)
TWILIO_WHATSAPP_FROM=

# ── 📧 Communications — SendGrid ─────────────────────────────────────────────
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ── 🔔 Notification Channels (Update Monitor) ────────────────────────────────
# See docs/UPDATE_MONITOR.md for setup instructions.
# Copy this block to /etc/openclaw/notify.env (chmod 0600) on control nodes.
NOTIFY_TELEGRAM=true
NOTIFY_SLACK=true
NOTIFY_DISCORD=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SLACK_WEBHOOK_URL=

DISCORD_WEBHOOK_URL=

# ── Update Monitor node config ────────────────────────────────────────────────
# MAIN_NODE=gateway-main
# WORKER_NODES_CSV=node1,node2,node3
# OPENCLAW_DIR=/opt/openclaw
# BACKUP_BASE=/root/openclaw_backups
# CHECK_INTERVAL=86400
# SSH_USER=deploy
# LOG_FILE=/var/log/openclaw_update.log