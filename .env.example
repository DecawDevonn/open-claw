# Flask configuration
FLASK_ENV=production
FLASK_DEBUG=false

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8080

# Logging
LOG_LEVEL=INFO

# API
API_VERSION=v1

# Database
# Leave unset to use in-memory storage (dev/testing only)
MONGODB_URI=mongodb://localhost:27017/open-claw

# Redis (for distributed rate limiting; falls back to in-memory if unset)
# REDIS_URL=redis://localhost:6379/0

# CORS - comma-separated list of allowed origins (* allows all)
CORS_ORIGINS=*

# Agent heartbeat timeout in seconds (agents marked offline after this many seconds without a heartbeat)
AGENT_HEARTBEAT_TIMEOUT=60
