FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here
HOST=0.0.0.0
PORT=8080
DATABASE_URL=
REDIS_URL=
LOG_LEVEL=
API_VERSION=
AGENT_HEARTBEAT_INTERVAL=

# ── Update Monitor (scripts/openclaw_multi_channel_update.sh) ────────────────
# Copy the block below to /etc/openclaw/notify.env (chmod 0600) on the control
# node. Set NOTIFY_*=false to disable channels you are not using.

NOTIFY_TELEGRAM=true
NOTIFY_SLACK=true
NOTIFY_DISCORD=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack
SLACK_WEBHOOK_URL=

# Discord
DISCORD_WEBHOOK_URL=

# Optional overrides (uncomment to customise)
# MAIN_NODE=gateway-main
# WORKER_NODES_CSV=node1,node2,node3
# OPENCLAW_DIR=/opt/openclaw
# BACKUP_BASE=/root/openclaw_backups
# CHECK_INTERVAL=86400
# SSH_USER=deploy
# LOG_FILE=/var/log/openclaw_update.log